generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" // default
}

datasource db {
  provider = "postgresql"
}

enum ConversationKind {
  gameInstanceChat
}

model GameChatMessage {
  conversationKind  ConversationKind
  conversationId    String
  chatMsgId         String   @id
  senderAccountId   String
  sentTs            Int
  msgText           String
  paginationId      Int      @default(autoincrement())

  @@index([chatMsgId])
  @@index([conversationId, paginationId])
}
